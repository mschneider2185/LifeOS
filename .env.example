# ============================================================
# LifeOS — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# NEVER commit .env.local — it contains real credentials.
# ============================================================

# ----------------------------------------------------------
# Supabase
# Get these from: https://app.supabase.com → Project Settings → API
# ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------
# Stripe
# Get these from: https://dashboard.stripe.com/apikeys
# Webhook secret from: https://dashboard.stripe.com/webhooks
# ----------------------------------------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ----------------------------------------------------------
# Notion
# Create an integration at: https://www.notion.so/my-integrations
# Then share each database with your integration.
# See scripts/setup-notion.md for full setup instructions.
# ----------------------------------------------------------
NOTION_API_KEY=

# Notion Database IDs (pre-configured — do not change unless you recreate the databases)
NOTION_CHECKIN_DB=be279e07e4494391936c8134f0d053d4
NOTION_GOALS_DB=17f3f35170e04ce2911fcb76182ba62f
NOTION_PROJECTS_DB=7254b157403c4640acae675505cc409d
NOTION_TASKS_DB=2d3e7ce2e2a080329387eddaa6263ee3
NOTION_HEALTH_DB=4e8edb28aaaf4486890d5245731f0db2
NOTION_BRAINDUMP_PAGE=331e7ce2e2a0814c94eef2d3a18a8a87
NOTION_ACTIVITY_LOG_DB_ID=267cebf8a1a04199b696d96860ed38d9

# ----------------------------------------------------------
# App
# ----------------------------------------------------------
NEXT_PUBLIC_APP_URL=
